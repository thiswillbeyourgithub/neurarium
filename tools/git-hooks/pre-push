#!/bin/sh
# pre-push hook: refuse to push anything other than the `main` branch.
#
# This guards against accidentally pushing a stray local branch (or tag) to a
# remote. Deploy here is by rsync, not git, so `main` is the only ref that ever
# legitimately leaves this machine.
#
# Tracked in the repo as the single source of truth and activated *locally*
# with:
#     git config core.hooksPath tools/git-hooks
# (a fresh clone must run that once; the setting lives in .git/config and is not
# itself committed). See CLAUDE.md "Git hooks".
#
# Git feeds this hook one line per ref being pushed on stdin:
#     <local ref> SP <local sha> SP <remote ref> SP <remote sha>
# We crash the push (non-zero exit) as soon as any local ref is not
# refs/heads/main. That also blocks tags (refs/tags/...) and branch deletes
# (local ref "(delete)"), which are likewise not "pushing main".

remote_name="$1"
status=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "$local_ref" ] && continue
  if [ "$local_ref" != "refs/heads/main" ]; then
    echo "pre-push: refusing to push '$local_ref' to '${remote_name:-remote}';" \
         "only the 'main' branch may be pushed from here." >&2
    status=1
  fi
done

# The branch is fine: offer to run the dataset integrity check
# (tools/check_data.py) before letting the push through. Prompt + answer go
# to the controlling terminal, because stdin here is git's ref list (consumed
# by the loop above), not the keyboard. A non-interactive push (no controlling
# terminal, e.g. a script) silently skips the prompt so it never hangs.
# Answering "y" runs the check and a *failed* check (data errors) aborts the
# push; warnings (e.g. the known TODO source urls) pass.
#
# The guard actually *opens* /dev/tty for writing rather than testing `-r`: the
# device node is readable-bit-set even with no controlling terminal, but opening
# it then fails with ENXIO. The probe runs in a *subshell* `( : >/dev/tty )`
# because `:` is a POSIX special built-in, so in dash a failed redirection on it
# would exit the whole shell (killing the hook); the subshell contains that, and
# its exit status is non-zero exactly when /dev/tty can't be opened, which is the
# real "are we interactive?" question.
if [ "$status" -eq 0 ] && ( : >/dev/tty ) 2>/dev/null; then
  printf 'pre-push: run the data integrity check (tools/check_data.py) first? [y/N] ' >/dev/tty
  read -r answer </dev/tty
  case "$answer" in
    [Yy]*)
      py=$(command -v python || command -v python3)
      if [ -z "$py" ]; then
        echo "pre-push: no python interpreter found; skipping the data check." >/dev/tty
      elif "$py" tools/check_data.py >/dev/tty 2>&1; then
        echo "pre-push: data check passed." >/dev/tty
      else
        echo "pre-push: data check reported errors; aborting push." >/dev/tty
        status=1
      fi
      ;;
    *)
      echo "pre-push: skipping the data check." >/dev/tty
      ;;
  esac
fi

exit "$status"
