# Caddy config for the static Neurarium brain visualizer.
#
# Listens on :8359 (the compose file maps it to 127.0.0.1:8359 on the host, so a
# reverse proxy is expected in front). Serves the project root, which is
# bind-mounted read-only at /srv by docker-compose.yml.

{
	# No ACME/TLS in here: TLS is terminated by the host reverse proxy. Turning
	# auto_https off keeps Caddy from trying to manage certs (it would fail on
	# the read-only rootfs anyway). admin off drops the local admin API surface.
	admin off
	auto_https off
}

:8359 {
	root * /srv

	encode gzip zstd

	# The runtime app config (window.__APP_CONFIG__) is rendered from the
	# container environment (ANALYTICS_* + DEV from docker/.env, STARTED_AT
	# stamped at start) by docker/entrypoint.sh into /gen, a writable tmpfs, at
	# container start; serve THAT for /app-config.js instead of the repo's static
	# local-dev fallback under /srv. Rendering once at startup, rather than
	# templating the file on every request, means Caddy never parses the JS as a
	# Go template, so a stray brace marker in the file can't 500 it (which used to
	# take analytics AND the DEV banner down together). The file is named
	# generically, not "analytics-*", so content filters / proxies that block
	# "analytics" paths don't 404 it.
	handle /app-config.js {
		root * /gen
		file_server
	}
	handle {
		file_server
	}

	# Basic hardening headers for a static, same-origin app. No restrictive CSP
	# because the page intentionally loads three.js + eruda from a CDN.
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
		-Server

		# Never let the browser serve a cached asset. This is a no-build site
		# whose ES modules / data are deployed by rsync (no content-hashed
		# filenames), so a heuristically-cached old js/*.js next to a fresh one
		# would crash with a baffling signature mismatch (see CLAUDE.md "Running").
		# Mirrors tools/serve.py's dev behaviour so dev and prod cache the same
		# way: always fetch the deployed version. (Swap to "no-cache" if you want
		# ETag revalidation / 304s back; "no-store" is the strongest guarantee.)
		Cache-Control "no-store"
	}

	log {
		output stdout
		format console
	}
}
