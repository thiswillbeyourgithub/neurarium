# Copy this file to docker/.env and fill in the values.
# docker compose automatically loads docker/.env when run from this directory.
#
# All values are optional: leave them empty to disable analytics entirely.

# umami analytics (privacy-friendly). Injected at runtime into the page.
#   ANALYTICS_URL         : full URL of the umami tracking SCRIPT (used verbatim
#                           as a <script src>), e.g.
#                           https://umami.example.com/script.js  -- NOT the
#                           instance base URL. If set, the container validates it
#                           at startup (must be reachable and serve JavaScript)
#                           and refuses to start otherwise; see docker/entrypoint.sh.
#   ANALYTICS_WEBSITE_ID  : the umami website id (UUID)
#   ANALYTICS_SRI         : optional Subresource Integrity hash for the script,
#                           e.g. sha384-... (umami must send CORS headers)
#   ANALYTICS_DNT         : umami "data-do-not-track" value. "true" (default)
#                           respects the browser's Do Not Track signal (those
#                           visitors are not tracked); "false" tracks everyone.
ANALYTICS_URL=
ANALYTICS_WEBSITE_ID=
ANALYTICS_SRI=
ANALYTICS_DNT=true

# DEV: "1" shows a "work in progress / this container was restarted X ago, come
# back later" banner across the top of the page (js/dev-banner.js). Defaults to
# "0" (no banner). Useful while actively redeploying the site. The "X ago" uses
# the container start time, stamped automatically at startup.
DEV=0
